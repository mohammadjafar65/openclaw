# ── SERVER ──────────────────────────────────────────────
PORT=3000
NODE_ENV=production
APP_URL=https://yourdomain.com
JWT_SECRET=change_this_to_a_random_64char_string_NOW
JWT_EXPIRES_IN=7d

# ── DATABASE (cPanel MySQL) ──────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=your_cpanel_dbname
DB_USER=your_cpanel_dbuser
DB_PASS=your_cpanel_dbpassword

# ── GOOGLE PLACES API ────────────────────────────────────
# Get free key: console.cloud.google.com → Places API
# $200/month free credit = ~16,000 searches free
GOOGLE_PLACES_API_KEY=your_google_places_api_key

# ── SERPAPI (alternative scraper, 100 free/month) ────────
SERPAPI_KEY=your_serpapi_key_optional

# ── ANTHROPIC (Claude AI for scoring & copy) ─────────────
ANTHROPIC_API_KEY=your_anthropic_api_key

# ── EMAIL (cPanel has free SMTP built in!) ───────────────
# Option A: cPanel built-in SMTP (FREE - use your hosting email)
SMTP_HOST=mail.yourdomain.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=outreach@yourdomain.com
SMTP_PASS=your_email_password
SMTP_FROM_NAME=Your Name
SMTP_FROM_EMAIL=outreach@yourdomain.com

# Option B: Gmail (500 free/day)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=yourgmail@gmail.com
# SMTP_PASS=your_app_password (not regular password!)

# Option C: Brevo (formerly Sendinblue) - 300 free/day
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your_brevo_login
# SMTP_PASS=your_brevo_smtp_key

# ── SMS (Twilio) - Optional ──────────────────────────────
TWILIO_ACCOUNT_SID=optional
TWILIO_AUTH_TOKEN=optional
TWILIO_FROM_NUMBER=optional

# ── HUNTER.IO (150 free searches/month) ─────────────────
HUNTER_API_KEY=optional_for_email_finder

# ── ADMIN USER ───────────────────────────────────────────
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change_this_strong_password
